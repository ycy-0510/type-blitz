# Server port (optional)
PORT=3001

# Cloudflare Turnstile secret key (verifies create/join challenges).
# Leave empty to DISABLE verification (local development only).
TURNSTILE_SECRET_KEY=

# --- Special edition (special-version branch) ---
# Optional custom quote used as the FIRST multiplayer match in every room.
# When set, finishing it triggers a 16-bit Happy Birthday tune + confetti/balloons.
# Subsequent matches in the same room return to the normal random pool.
CUSTOM_QUOTE=
CUSTOM_QUOTE_SOURCE=Special Edition

# Number of typing passages in client/public/quotes.json. The server picks a
# random index in [0, QUOTE_COUNT). Keep in sync if you regenerate quotes.json.
QUOTE_COUNT=3000
