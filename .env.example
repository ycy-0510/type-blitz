# Cloudflare Turnstile keys (used by docker-compose)
# Create a widget at: https://dash.cloudflare.com/?to=/:account/turnstile
#
# For local testing Cloudflare provides "always pass" dummy keys:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA

# Public site key — embedded into the client bundle at build time.
TURNSTILE_SITE_KEY=

# Secret key — used by the server to verify tokens. Keep this private.
TURNSTILE_SECRET_KEY=

# --- Special edition (special-version branch) ---
# Optional custom quote used as the FIRST multiplayer match in every room.
# Finishing it plays a 16-bit Happy Birthday tune + confetti/balloons; the
# next match in the same room returns to the normal random pool.
CUSTOM_QUOTE=
CUSTOM_QUOTE_SOURCE=Special Edition
